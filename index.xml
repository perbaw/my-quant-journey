<span id="cb1-16">plt.ylabel(<span class="st" style="color: #20794D;
background-color: null;
font-style: inherit;">"Delta"</span>) </span>
<span id="cb1-17">plt.legend() </span>
<span id="cb1-18">plt.show()</span></code></pre></div></div>
